# ==============================================================
# Environment Variables cho AI Chatbot RAG System
# Copy file này thành .env và điền giá trị thực tế
# ==============================================================

# ── LLM Configuration ────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ── Embedding Configuration ──────────────────────────────────
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Reranker Configuration ───────────────────────────────────
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5

# ── ChromaDB Configuration ───────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=movie_collection

# ── MongoDB Configuration (Chat History) ─────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=movie_chatbot
MONGODB_COLLECTION_HISTORY=chat_history

# ── MySQL Configuration (Source Data) ────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=movie_streaming_db

# ── Chunking Configuration ───────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Retrieval Configuration ──────────────────────────────────
RETRIEVAL_TOP_K=10
HYBRID_SEARCH_ALPHA=0.5

# ── API Configuration ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8002
